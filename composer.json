{
    "name": "sendaramail/sendara",
    "description": "Sendara — email & marketing API (transactional email, broadcasts, contacts, templates, webhooks) for PHP. Zero runtime dependencies.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "sendara",
        "email",
        "transactional",
        "broadcasts",
        "messaging",
        "api",
        "webhooks",
        "laravel"
    ],
    "homepage": "https://sendara.dev",
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10"
    },
    "autoload": {
        "psr-4": {
            "Sendara\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sendara\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sendara\\Laravel\\SendaraServiceProvider"
            ],
            "aliases": {
                "Sendara": "Sendara\\Laravel\\SendaraFacade"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
